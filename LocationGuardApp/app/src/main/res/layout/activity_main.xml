<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="#FFFAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📍 位置守护"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FF333333"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="配合 AstrBot location_guard 插件使用"
            android:textSize="13sp"
            android:textColor="#FF999999"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- 状态 -->
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="○ 未启动"
            android:textSize="18sp"
            android:textColor="#FF9E9E9E"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- 服务器地址 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="服务器地址"
            android:textSize="14sp"
            android:textColor="#FF666666"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_server_url"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="http://你的服务器IP:8090"
            android:inputType="textUri"
            android:textSize="15sp"
            android:padding="12dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="16dp" />

        <!-- 上报间隔 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="上报间隔 (分钟)"
            android:textSize="14sp"
            android:textColor="#FF666666"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_interval"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="10"
            android:inputType="number"
            android:textSize="15sp"
            android:padding="12dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="16dp" />

        <!-- 家的坐标 -->
        <Button
            android:id="@+id/btn_get_location"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:text="📍 获取当前位置作为家的坐标"
            android:textSize="14sp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="家的纬度 (lat)"
            android:textSize="14sp"
            android:textColor="#FF666666"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_home_lat"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="28.xxxxx"
            android:inputType="numberDecimal|numberSigned"
            android:textSize="15sp"
            android:padding="12dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="家的经度 (lng)"
            android:textSize="14sp"
            android:textColor="#FF666666"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_home_lng"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="115.xxxxx"
            android:inputType="numberDecimal|numberSigned"
            android:textSize="15sp"
            android:padding="12dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="16dp" />

        <!-- 警报距离 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="离家警报距离 (米)"
            android:textSize="14sp"
            android:textColor="#FF666666"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_alert_distance"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="500"
            android:inputType="number"
            android:textSize="15sp"
            android:padding="12dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="32dp" />

        <!-- 按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btn_start"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="启动守护"
                android:textSize="16sp"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btn_stop"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="停止守护"
                android:textSize="16sp"
                android:enabled="false"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <!-- 底部信息 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="提示: 请确保已授予定位权限和后台定位权限\n建议关闭电池优化以保证服务稳定运行"
            android:textSize="12sp"
            android:textColor="#FFAAAAAA"
            android:gravity="center"
            android:layout_marginTop="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="© 2026 沈菀 | AGPL-3.0"
            android:textSize="11sp"
            android:textColor="#FFCCCCCC"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp" />

    </LinearLayout>

</ScrollView>
